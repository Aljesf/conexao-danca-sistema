  "def_flat": {
    "name": "def_flat",
    "ok": true,
    "rows": [
      {
        "definition": " WITH receb AS (\n         SELECT r.cobranca_id,\n            COALESCE(sum(r.valor_centavos), (0)::bigint) AS valor_recebido_centavos\n           FROM recebimentos r\n          GROUP BY r.cobranca_id\n        ), base AS (\n         SELECT c.id AS cobranca_id,\n            c.pessoa_id,\n            c.vencimento,\n            c.status AS status_cobranca,\n            c.origem_tipo,\n            c.origem_id,\n            c.created_at,\n            COALESCE(c.valor_centavos, 0) AS valor_total_centavos,\n            COALESCE(rec.valor_recebido_centavos, (0)::bigint) AS valor_recebido_centavos,\n            GREATEST((COALESCE(c.valor_centavos, 0) - COALESCE(rec.valor_recebido_centavos, (0)::bigint)), (0)::bigint) AS saldo_aberto_centavos\n           FROM (cobrancas c\n             LEFT JOIN receb rec ON ((rec.cobranca_id = c.id)))\n        )\n SELECT cobranca_id,\n    pessoa_id,\n    vencimento AS data_vencimento,\n    status_cobranca,\n    origem_tipo,\n    origem_id,\n    created_at,\n    valor_total_centavos,\n    valor_recebido_centavos,\n    saldo_aberto_centavos,\n    to_char((COALESCE(vencimento, CURRENT_DATE))::timestamp with time zone, 'YYYY-MM'::text) AS competencia_ano_mes,\n        CASE\n            WHEN ((vencimento IS NOT NULL) AND (vencimento < CURRENT_DATE) AND (saldo_aberto_centavos > 0)) THEN (CURRENT_DATE - vencimento)\n            ELSE 0\n        END AS dias_atraso,\n        CASE\n            WHEN (saldo_aberto_centavos = 0) THEN 'QUITADA'::text\n            WHEN ((vencimento IS NOT NULL) AND (vencimento < CURRENT_DATE)) THEN 'VENCIDA'::text\n            ELSE 'EM_ABERTO'::text\n        END AS situacao_saas,\n        CASE\n            WHEN (vencimento IS NULL) THEN 'SEM_VENCIMENTO'::text\n            WHEN ((vencimento < CURRENT_DATE) AND (saldo_aberto_centavos > 0)) THEN 'VENCIDA'::text\n            WHEN ((vencimento >= CURRENT_DATE) AND (vencimento <= (CURRENT_DATE + 7)) AND (saldo_aberto_centavos > 0)) THEN 'A_VENCER_7'::text\n            WHEN ((vencimento > (CURRENT_DATE + 7)) AND (vencimento <= (CURRENT_DATE + 30)) AND (saldo_aberto_centavos > 0)) THEN 'A_VENCER_30'::text\n            WHEN ((vencimento > (CURRENT_DATE + 30)) AND (saldo_aberto_centavos > 0)) THEN 'FUTURA'::text\n            ELSE 'QUITADA_OU_ZERO'::text\n        END AS bucket_vencimento\n   FROM base b;"
      }
    ],
    "rowCount": 1
  },
  "def_devedores": {
    "name": "def_devedores",
    "ok": true,
    "rows": [
      {
        "definition": " SELECT pessoa_id,\n    (count(*))::integer AS titulos_vencidos_qtd,\n    (sum(saldo_aberto_centavos))::integer AS total_vencido_centavos,\n    min(data_vencimento) AS vencimento_mais_antigo,\n    max(dias_atraso) AS maior_dias_atraso\n   FROM vw_financeiro_contas_receber_flat f\n  WHERE ((situacao_saas = 'VENCIDA'::text) AND (saldo_aberto_centavos > 0))\n  GROUP BY pessoa_id;"
      }
    ],
    "rowCount": 1
  }
