{
  "name": "pdv-bale-cafe",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:rebuild": "cd android && gradlew.bat :app:assembleDebug -PreactNativeArchitectures=x86_64",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export:android": "expo export --platform android",
    "ios": "expo run:ios"
  },
  "expo": {
    "autolinking": {
      "searchPaths": [
        "../../node_modules"
      ]
    }
  },
  "dependencies": {
    "@expo/env": "^2.1.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "@supabase/supabase-js": "^2.89.0",
    "expo": "54.0.33",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
